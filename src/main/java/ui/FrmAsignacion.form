<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.FrmAsignacion">
  <grid id="2b3c" binding="panelAsignacion" row-count="5" column-count="1" layout-manager="GridLayoutManager">
    <margin top="15" left="15" bottom="15" right="15"/>
    <constraints>
      <xy x="0" y="0" width="500" height="400"/>
      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="b1" class="javax.swing.JComboBox" binding="cbEspecialidad">
        <constraints><grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints>
        <properties/>
      </component>
      <scrollpane id="b2">
        <constraints><grid row="1" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/></constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="b3" class="javax.swing.JTable" binding="tbPersonalEnTurno">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
      <component id="b4" class="javax.swing.JButton" binding="btnLlamarSiguientePaciente">
        <constraints><grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
        <properties><text value="Llamar Siguiente Paciente"/></properties>
      </component>
      <component id="b5" class="javax.swing.JButton" binding="btnRegistrarDiagnostico">
        <constraints><grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
        <properties><text value="Registrar Diagnóstico"/></properties>
      </component>
      <component id="b6" class="javax.swing.JButton" binding="btnDarAlta">
        <constraints><grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
        <properties><text value="Dar de Alta"/></properties>
      </component>
    </children>
  </grid>
</form>